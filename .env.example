# ---- OpenRouter (recommended) ----
# Get a key at https://openrouter.ai/keys  (free tier available)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model + fallback chain (tried in order on rate-limit / model errors)
DEFAULT_MODEL=openai/gpt-4o-mini
FALLBACK_MODELS=anthropic/claude-3.5-haiku,google/gemini-flash-1.5,deepseek/deepseek-chat

# ---- OR use a direct OpenAI key instead ----
# OPENAI_API_KEY=sk-...
# (if set and OPENROUTER_API_KEY is empty, swap config.py to use the official base_url)
